    "loc.archive.empty.list" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🫙 The archive list is empty.\n\nIf there are diffusers in your diffuser list \nthat you no longer use, you can add them \nto the archive using the [Archive] feature!"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🫙 アーカイブリストが空です。\n\nディフューザーリストで、もう使わな\nくなったディフューザーがある場合は、\n[保管]機能を利用すればアーカイブに\n追加できます！"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🫙 아카이브 리스트가 비어있어요.\n\n디퓨저 리스트에서 더 이상 사용하지\n않는 디퓨저가 있는 경우 [보관] 기능을\n이용하면 아카이브에 추가할 수 있어요!"
          }
        }
      }
